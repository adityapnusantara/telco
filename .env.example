# OpenAI Configuration
OPENAI_API_KEY=sk-proj-...

# Langfuse Configuration
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# OpenTelemetry Configuration (fixes context warning with FastAPI async)
OTEL_PYTHON_CONTEXT=process_context

# Qdrant Cloud Configuration
QDRANT_URL=https://...
QDRANT_API_KEY=...
QDRANT_COLLECTION_NAME=telco_knowledge_base

# Embedding Configuration
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Application Configuration
APP_ENV=development
LOG_LEVEL=info

# Suppress OpenTelemetry context warnings (FastAPI async issue)
OTEL_SDK_DISABLED=false